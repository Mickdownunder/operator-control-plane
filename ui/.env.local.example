# Absolute path to the operator-control-plane repository root.
OPERATOR_ROOT=/absolute/path/to/operator-control-plane

# Required auth settings.
# Preferred format:
#   node -e 'const crypto=require("crypto"); const password="replace-me"; const salt=crypto.randomBytes(16); const N=16384,r=8,p=1; const hash=crypto.scryptSync(password,salt,64,{N,r,p,maxmem:128*N*r+1024*1024}); console.log(`scrypt$${N}$${r}$${p}$${salt.toString("hex")}$${hash.toString("hex")}`)'
# Legacy format still accepted:
#   echo -n "replace-me" | sha256sum | cut -d" " -f1
UI_PASSWORD_HASH=replace_with_scrypt_or_legacy_sha256_hash
UI_SESSION_SECRET=replace_with_random_secret

# Optional notifications.
UI_TELEGRAM_NOTIFY=0

# Optional login hardening (defaults shown).
UI_LOGIN_MAX_ATTEMPTS=5
UI_LOGIN_WINDOW_SECONDS=300
UI_LOGIN_LOCK_SECONDS=300
