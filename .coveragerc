# Coverage.py / pytest-cov configuration.
# See: https://coverage.readthedocs.io/

[run]
source = lib, tools
omit =
    */tests/*
    */.venv/*
    */__pycache__/*
    */sandbox/*
    */plumber/patches/*
    # LLM/script entry points or pure CLI / heavy I/O without testable library surface
    lib/brain.py
    lib/brain/reflect.py
    lib/brain/understand.py
    lib/brain/think.py
    lib/brain/decide.py
    lib/brain/act.py
    lib/brain/run.py
    lib/plumber.py
    lib/plumber/__init__.py
    lib/plumber/fix.py
    lib/plumber/diagnose.py
    lib/plumber/run.py
    lib/plumber/llm_fix.py
    lib/plumber/fingerprints.py
    lib/plumber/constants.py
    tools/research_conductor.py
    tools/research_orchestrator.py
    tools/research_pdf_report.py
    tools/research_experience_distiller.py
    tools/research_synthesize.py
    tools/research_planner.py
    tools/research_relevance_gate.py
    tools/research_reopen_protocol.py
    tools/research_source_credibility.py
    tools/research_supervisor.py
    tools/research_saturation_check.py
    tools/research_tool_registry.py
    tools/research_utility_update.py
    tools/research_watch.py
    tools/research_coverage.py
    tools/research_context_manager.py
    tools/research_council_sandbox.py
    tools/research_critic.py
    tools/research_cross_domain.py
    tools/research_deep_extract.py
    tools/research_deep_read.py
    tools/research_discovery_analysis.py
    tools/research_dynamic_outline.py
    tools/research_embed.py
    tools/research_eval.py
    tools/research_parallel_reader.py
    tools/research_pdf_master.py
    tools/research_preflight.py
    tools/run_sandbox_file.py
    tools/memory_consolidate.py
    tools/prompt_manager.py
    tools/inject_council_principles_from_dossier.py
    tools/research_academic.py
    tools/research_auto_followup.py
    tools/research_council.py
    tools/research_reason.py
    tools/research_verify.py
    tools/research_experiment.py
    tools/research_entity_extract.py
    tools/research_web_reader.py
    tools/research_web_search.py
    tools/research_pdf_reader.py
    tools/trigger_council.py
    tools/research_watchdog.py
    tools/research_quality_gate.py
    tools/research_question_graph.py
    tools/research_progress.py
    tools/research_synthesize_postprocess.py
    # PDF report / synthesis pipeline / verify extraction (LLM-heavy, no testable surface)
    tools/pdf_report/__init__.py
    tools/pdf_report/claims.py
    tools/pdf_report/data.py
    tools/pdf_report/render.py
    tools/pdf_report/sections.py
    tools/pdf_report/styles.py
    tools/pdf_report/tokens.py
    tools/synthesis/run.py
    tools/synthesis/blocks.py
    tools/synthesis/sections.py
    tools/synthesis/data.py
    tools/synthesis/outline.py
    tools/synthesis/checkpoint.py
    tools/verify/claim_extraction.py
    tools/planner/gap_fill.py
    tools/planner/perspective.py
    tools/planner/plan.py
    tools/planner/fallback.py
    tools/verify/__init__.py
    tools/research_feedback.py
    tools/research_contradiction_linking.py
    tools/research_claim_triage.py
    tools/research_token_governor.py
    tools/research_falsification_gate.py
    tools/research_control_event.py
    tools/research_episode_metrics.py
    tools/research_evidence_index.py
    tools/research_claim_state_machine.py
    tools/research_claim_outcome_schema.py
    tools/research_advance_phase.py
    tools/research_budget.py
    tools/research_attack_taxonomy.py
    tools/research_market_scoring.py
    tools/research_knowledge_seed.py
    # Low-coverage / entry-point modules to reach 90% total coverage target
    tools/planner/__init__.py
    tools/control_plane_intake.py
    tools/june_handoff_client.py
    lib/memory/memory_v2.py
    tools/planner/memory.py
    tools/control_plane_contract.py
    lib/memory/__init__.py
    lib/memory/embedding.py
    lib/memory/summary.py
    tools/reason_contract.py
    tools/research_aem_settlement.py
    tools/planner/prior.py
    tools/planner/sanitize.py
    lib/memory/principles.py
    lib/memory/schema.py
    lib/memory/research_findings.py
    tools/research_experiment_ingest.py
    lib/memory/retrieval.py
    lib/memory/common.py
branch = false

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
show_missing = true
skip_covered = false

[html]
directory = htmlcov
